---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'grassLog — 草を生やすブログ' } = Astro.props;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | grassLog</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --green: #16a34a;
        --green-light: #dcfce7;
        --text: #111827;
        --muted: #6b7280;
        --border: #e5e7eb;
        --bg: #f9fafb;
        --card: #ffffff;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.7;
        min-height: 100vh;
      }

      header {
        border-bottom: 1px solid var(--border);
        background: var(--card);
      }

      .header-inner {
        max-width: 720px;
        margin: 0 auto;
        padding: 1rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .logo {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--green);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }

      .logo::before { content: '🌿'; }

      nav a {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.15s;
      }

      nav a:hover { color: var(--green); }

      main {
        max-width: 720px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem;
      }

      footer {
        text-align: center;
        padding: 2rem 1.5rem;
        color: var(--muted);
        font-size: 0.85rem;
        border-top: 1px solid var(--border);
      }
    </style>
  </head>
  <body>
    <header>
      <div class="header-inner">
        <a href="/" class="logo">grassLog</a>
        <nav>
          <a href="/new">+ 記事を書く</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      grassLog — 書けば草が生える
    </footer>
  </body>
</html>
