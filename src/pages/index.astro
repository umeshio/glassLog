---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = (await getCollection('posts')).sort(
  (a: CollectionEntry<'posts'>, b: CollectionEntry<'posts'>) =>
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const rendered = await Promise.all(
  posts.map(async (post: CollectionEntry<'posts'>) => {
    const { Content } = await render(post);
    return { post, Content };
  })
);
---

<Layout title="ホーム">
  <style>
    h1 {
      font-size: 1.75rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .subtitle {
      color: var(--muted);
      margin-bottom: 2.5rem;
      font-size: 0.95rem;
    }

    .post-list {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .post-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.5rem;
    }

    .post-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1rem;
      padding-bottom: 0.875rem;
      border-bottom: 1px solid var(--border);
    }

    .post-title {
      font-size: 1.15rem;
      font-weight: 700;
    }

    .post-date {
      font-size: 0.8rem;
      color: var(--green);
      font-weight: 500;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .prose {
      font-size: 0.95rem;
      line-height: 1.8;
      color: var(--text);
    }

    .prose :global(h2) { font-size: 1.1rem; font-weight: 600; margin: 1.25rem 0 0.5rem; }
    .prose :global(h3) { font-size: 1rem;   font-weight: 600; margin: 1rem 0 0.4rem; }
    .prose :global(p)  { margin-bottom: 0.875rem; }
    .prose :global(p:last-child) { margin-bottom: 0; }

    .prose :global(ul), .prose :global(ol) {
      padding-left: 1.4rem;
      margin-bottom: 0.875rem;
    }

    .prose :global(li) { margin-bottom: 0.2rem; }

    .prose :global(code) {
      background: var(--green-light);
      color: var(--green);
      padding: 0.1em 0.35em;
      border-radius: 4px;
      font-size: 0.88em;
    }

    .prose :global(pre) {
      background: #1e293b;
      color: #e2e8f0;
      padding: 1rem 1.25rem;
      border-radius: 8px;
      overflow-x: auto;
      margin-bottom: 0.875rem;
    }

    .prose :global(pre code) { background: none; color: inherit; padding: 0; }

    .prose :global(blockquote) {
      border-left: 3px solid var(--green);
      padding-left: 1rem;
      color: var(--muted);
      margin: 0.875rem 0;
    }

    .prose :global(a)  { color: var(--green); }
    .prose :global(hr) { border: none; border-top: 1px solid var(--border); margin: 1rem 0; }

    .empty {
      text-align: center;
      color: var(--muted);
      padding: 3rem 0;
    }
  </style>

  <h1>記事一覧</h1>
  <p class="subtitle">{posts.length} 件の記事</p>

  {rendered.length === 0 ? (
    <div class="empty">まだ記事がありません。<a href="/new">最初の記事を書く</a></div>
  ) : (
    <div class="post-list">
      {rendered.map(({ post, Content }) => (
        <article class="post-card">
          <div class="post-header">
            <div class="post-title">{post.data.title}</div>
            <time class="post-date" datetime={post.data.date}>{post.data.date}</time>
          </div>
          <div class="prose">
            <Content />
          </div>
        </article>
      ))}
    </div>
  )}
</Layout>
